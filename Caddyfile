{
    email {$ACME_EMAIL}
}

(common_headers) {
    encode zstd gzip
    header {
        -Server
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }
}

{$FACEAPP_DOMAIN} {
    import common_headers
    reverse_proxy {$FACEAPP_UPSTREAM} {
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Proto {scheme}
    }
}

https://{$FACEAPP_API_DOMAIN} {
    import common_headers
    header Strict-Transport-Security "max-age=31536000"
    reverse_proxy {$FACEAPP_UPSTREAM} {
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Proto https
    }
}

http://{$FACEAPP_API_DOMAIN} {
    import common_headers
    @device_http path /api/device/callbacks/* /storage/*

    handle @device_http {
        reverse_proxy {$FACEAPP_UPSTREAM} {
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto http
        }
    }

    redir https://{$FACEAPP_API_DOMAIN}{uri} 308
}

{$QBOTU_DOMAIN} {
    import common_headers
    reverse_proxy {$QBOTU_UPSTREAM}
}

{$QBOTU_API_DOMAIN} {
    import common_headers
    reverse_proxy {$QBOTU_UPSTREAM}
}

{$QBOTU_MINIO_DOMAIN} {
    import common_headers
    reverse_proxy {$QBOTU_UPSTREAM}
}
